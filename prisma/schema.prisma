generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Restaurant {
  id        Int      @id @default(autoincrement())
  name      String
  address   String
  visits    Visit[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Reviewer {
  id      Int      @id @default(autoincrement())
  name    String
  surname String
  reviews Review[]
}

model Visit {
  id           Int        @id @default(autoincrement())
  visitedAt    DateTime   @default(now())
  reviews      Review[]
  restaurantId Int
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
}

model Review {
  id Int @id @default(autoincrement())

  // ratings
  foodRating     Float @default(0)
  beverageRating Float @default(0)
  serviceRating  Float @default(0)
  valueRating    Float @default(0)
  ambianceRating Float @default(0)
  // end ratings

  reviewerId Int
  reviewer   Reviewer @relation(fields: [reviewerId], references: [id])
  visitId    Int
  visit      Visit    @relation(fields: [visitId], references: [id])
  createdAt  DateTime @default(now())
}
