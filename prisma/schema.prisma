generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Restaurant {
  id        Int      @id @default(autoincrement())
  name      String
  reviews   Review[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Reviewer {
  id      Int      @id @default(autoincrement())
  name    String
  surname String
  reviews Review[]
}

model Review {
  id         Int      @id @default(autoincrement())
  reviewerId Int
  reviewer   Reviewer @relation(fields: [reviewerId], references: [id])

  // ratings
  foodRating     Float @default(0)
  beverageRating Float @default(0)
  serviceRating  Float @default(0)
  valueRating    Float @default(0)
  ambianceRating Float @default(0)
  // end ratings

  restaurantId Int
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  createdAt    DateTime   @default(now())
}
