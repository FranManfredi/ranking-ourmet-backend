generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Restaurant {
  id        Int      @id @default(autoincrement())
  name      String
  address   String
  city      String   @default("MAR DEL PLATA")
  tags      String[]
  visits    Visit[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Reviewer {
  id      Int      @id @default(autoincrement())
  name    String
  surname String
  reviews Review[]

  // Vínculo con Autenticación
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Visit {
  id           Int        @id @default(autoincrement())
  visitedAt    DateTime   @default(now())
  reviews      Review[]
  restaurantId Int
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
}

model Review {
  id Int @id @default(autoincrement())

  // ratings
  foodRating     Float @default(0)
  beverageRating Float @default(0)
  serviceRating  Float @default(0)
  valueRating    Float @default(0)
  ambianceRating Float @default(0)
  // end ratings

  reviewerId Int
  reviewer   Reviewer @relation(fields: [reviewerId], references: [id])
  visitId    Int
  visit      Visit    @relation(fields: [visitId], references: [id])
  createdAt  DateTime @default(now())
}

// Better Auth Models
model User {
  id            String    @id
  name          String
  surname       String?
  email         String
  emailVerified Boolean
  image         String?
  role          String    @default("user")
  banned        Boolean   @default(false)
  createdAt     DateTime
  updatedAt     DateTime
  sessions      Session[]
  accounts      Account[]

  // Relación con Reviewer
  reviewer Reviewer?

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}
